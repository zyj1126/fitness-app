{
  "permissions": {
    "allow": [
      "Bash(python3 *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:8080/)",
      "Bash(npx --yes serve . -p 8080 --no-clipboard)",
      "Bash(curl -s -w \"\\\\n%{http_code}\" http://localhost:8080/)",
      "Bash(npx --yes http-server . -p 8080 -c-1 --silent)",
      "Bash(curl -s -w \"\\\\nHTTP_STATUS:%{http_code}\" http://localhost:8080/)",
      "Bash(start *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)"
    ]
  }
}
